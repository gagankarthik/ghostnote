# ── Ghostnote environment template ────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored — never commit real keys.
#
# NOTE: API keys (OpenAI, Deepgram) are NOT read from env vars at runtime.
# They are entered through the app's Settings panel and persisted locally in:
#   %APPDATA%\com.ghostnote.app\settings.json  (Windows)
#
# The vars below are Vite build-time overrides for development only.
# ──────────────────────────────────────────────────────────────────────────────

# Override the Tauri dev server port (default: 1420)
# VITE_PORT=1420

# Set to "true" to enable verbose Tauri IPC logging in the browser console
# VITE_DEBUG=false

# Tauri uses these internally during `npm run tauri dev` — do not change
# TAURI_SIGNING_PRIVATE_KEY=
# TAURI_SIGNING_PRIVATE_KEY_PASSWORD=
