{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ghostnote",
  "version": "0.1.0",
  "identifier": "com.ghostnote.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "plugins": {},
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Ghostnote",
        "width": 420,
        "height": 600,
        "minWidth": 320,
        "minHeight": 180,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": false,
        "resizable": true,
        "shadow": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
